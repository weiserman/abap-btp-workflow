@EndUserText.label: 'Approval - Object Type Config Service'
define service ZSD_APPR_OBJ_TYPE {
  expose ZC_APPR_OBJ_TYPE      as ObjectType;
  expose ZC_APPR_RULE          as ApprovalRule;
  expose ZC_APPR_CONDITION     as RuleCondition;
  expose ZC_APPR_INSTANCE      as ApprovalInstance;
  expose ZC_APPR_INSTANCE_CTX  as ApprovalContext;
  expose ZI_APPR_ROLE_VH       as RoleValueHelp;
  expose ZI_APPR_AGENT_TYPE_VH as AgentTypeValueHelp;
}